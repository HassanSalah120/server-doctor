# ServerDoctor Environment Configuration
# Copy this file to .env and customize as needed
# All values shown are defaults - uncomment and modify to override

# =============================================================================
# Scan Configuration
# =============================================================================

# Job timeout in seconds (0 = disabled, no timeout)
# Set to 0 to allow scans to run indefinitely until completion
server_doctor_JOB_TIMEOUT=0

# Maximum parallel scan workers (default: 1)
# SSH scans are resource-intensive - increase only if you have powerful hardware
# server_doctor_MAX_WORKERS=1

# Custom config directory path
# Override the default location for ServerDoctor configuration files
# server_doctor_CONFIG=~/.config/server-doctor

# =============================================================================
# DevOps Checks (Legacy - now controlled via UI)
# =============================================================================

# Enable DevOps supply-chain checks by default (0=off, 1=on)
# Deprecated: Now controlled via UI scan options
# server_doctor_DEVOPS_CHECKS=0

# Comma-separated list of repository paths to scan for CI/CD posture
# Deprecated: Now controlled via UI scan options
# Example: /var/www/,/home/user/projects/myapp
# server_doctor_REPO_SCAN_PATHS=

# Single repository path (legacy, use server_doctor_REPO_SCAN_PATHS instead)
# server_doctor_REPO_SCAN_PATH=

# =============================================================================
# Probe Settings
# =============================================================================

# Enable upstream health probes (0=off, 1=on)
# Probes active upstream targets to check availability
# server_doctor_ACTIVE_PROBES=1

# Enable WebSocket probes (0=off, 1=on)
# Tests WebSocket endpoints for connectivity
# server_doctor_WS_PROBES=1

# =============================================================================
# AI Diagnosis
# =============================================================================

# OpenAI API key for AI-powered diagnosis (optional)
# If not set, uses rule-based diagnosis instead
# OPENAI_API_KEY=sk-...

# Anthropic API key for Claude-based diagnosis (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI API key for Gemini-based diagnosis (optional)
# GOOGLE_API_KEY=...

# =============================================================================
# Notifications (Slack)
# =============================================================================

# Slack webhook URL for scan notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Slack channel to post notifications (overrides webhook default)
# SLACK_CHANNEL=#alerts

# Slack bot username
# SLACK_USERNAME=ServerDoctor

# =============================================================================
# Notifications (Email)
# =============================================================================

# SMTP server for email notifications
# SMTP_HOST=smtp.gmail.com

# SMTP port
# SMTP_PORT=587

# SMTP username
# SMTP_USER=your-email@gmail.com

# SMTP password or app-specific password
# SMTP_PASS=your-app-password

# Email sender address
# EMAIL_FROM=server-doctor@yourdomain.com

# =============================================================================
# Notifications (Webhook)
# =============================================================================

# Generic webhook URL for custom integrations
# WEBHOOK_URL=https://your-api.com/webhook

# Webhook authentication token/header
# WEBHOOK_TOKEN=your-secret-token

# =============================================================================
# Kubernetes
# =============================================================================

# Path to kubeconfig file
# KUBECONFIG=~/.kube/config

# Default Kubernetes namespace for scans
# K8S_NAMESPACE=default

# =============================================================================
# Security / Hardening
# =============================================================================

# Enable safe auto-fix mode (0=off, 1=on)
# WARNING: Only enable if you understand the risks
# AUTO_FIX_ENABLED=0

# Require confirmation for destructive operations (0=no, 1=yes)
# CONFIRM_DESTRUCTIVE=1

# =============================================================================
# Development / Debug
# =============================================================================

# Enable debug logging (0=off, 1=on)
# DEBUG=0

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Enable verbose scanner output
# VERBOSE=0

# =============================================================================
# Database
# =============================================================================

# SQLite database path (default: ./data/server_doctor.db)
# DATABASE_URL=sqlite:///data/server_doctor.db

# =============================================================================
# Report Generation
# =============================================================================

# Output directory for HTML reports
# REPORTS_DIR=./data/reports

# Default report format: html, json, yaml, markdown
# REPORT_FORMAT=html

# =============================================================================
# Feature Flags
# =============================================================================

# Enable experimental analyzers (0=off, 1=on)
# EXPERIMENTAL_FEATURES=0

# Disable specific checks (comma-separated rule IDs)
# DISABLED_CHECKS=NGX-SEC-001,NGX-SEC-002

# =============================================================================
# SSH / Connection
# =============================================================================

# Default SSH timeout in seconds
# SSH_TIMEOUT=30

# SSH connection retries
# SSH_RETRIES=3

# SSH key path (default: ~/.ssh/id_rsa)
# SSH_KEY_PATH=~/.ssh/id_rsa
