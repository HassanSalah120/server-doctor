upstream ws_backend {
    server 127.0.0.1:3000;
}

server {
    listen 443 ssl;
    server_name ws.example.com;

    location /ws-app/ {
        proxy_pass http://ws_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
